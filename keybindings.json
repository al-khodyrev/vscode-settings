[
    // Open Explorer
    {"key": "shift+cmd+e", "command": "workbench.view.explorer"},
    // Open Outline
    {"key": "shift+cmd+o", "command": "outline.open"},
    // Open Git
    {"key": "shift+cmd+g", "command": "workbench.view.scm"},
    // Open Terminal
    {"key": "shift+cmd+t", "command": "workbench.action.togglePanel"},
    // Open Recent
    {"key": "cmd+r", "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup"},
    // Code Navigation
    {"key": "cmd+[", "command": "workbench.action.navigateBack"},
    {"key": "cmd+]", "command": "workbench.action.navigateForward"}
]

